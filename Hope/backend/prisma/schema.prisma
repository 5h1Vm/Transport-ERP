// Transit Ledger — Prisma Schema
// Fleet Operating System for Indian Transport Businesses

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═════════════════════════════════════════════════
// MULTI-TENANCY
// ════════════════════════════════════════════════

model Organization {
  id        String   @id @default(cuid())
  name      String
  gstin     String?
  pan       String?
  address   String?
  phone     String?
  language  String   @default("hi") // hi | en
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  vehicles       Vehicle[]
  drivers        Driver[]
  transporters   Transporter[]
  parties        Party[]
  routes         Route[]
  trips          Trip[]
  documents      Document[]
  ledgerAccounts LedgerAccount[]
}

// ═════════════════════════════════════════════════
// AUTHENTICATION & USERS
//  ═══════════════════════════════════════════════════

enum Role {
  OWNER
  MANAGER
  DISPATCHER
  ACCOUNTANT
  TRANSPORTER
  DRIVER
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String?  @unique
  phone          String?
  name           String
  passwordHash   String
  role           Role
  language       String   @default("hi")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // For TRANSPORTER role — link to their transporter record
  transporterId String?      @unique
  transporter   Transporter? @relation(fields: [transporterId], references: [id])

  // For DRIVER role — link to their driver record
  driverId String? @unique
  driver   Driver? @relation(fields: [driverId], references: [id])

  organization Organization @relation(fields: [organizationId], references: [id])

  createdTrips     Trip[]     @relation("TripCreator")
  createdPayments  Payment[]  @relation("PaymentCreator")
  createdDocuments Document[] @relation("DocumentCreator")

  @@unique([organizationId, email])
  @@index([organizationId])
}

// ═════════════════════════════════════════════════
// MASTER DATA — TRANSPORTERS
// ═════════════════════════════════════════════════

enum CommissionType {
  PERCENTAGE
  FIXED_PER_TRIP
  FIXED_PER_TON
}

model Transporter {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  firmName       String
  contactPerson  String?
  phone          String?
  email          String?
  gstin          String?
  pan            String?
  address        String?
  isActive       Boolean      @default(true)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user      User? // for TRANSPORTER self-login
  trips     Trip[]
  rateCards RateCard[]
  ledger    TransporterLedgerEntry[]
  payments  Payment[]
  tripLoads TripLoad[] // multi-stop legs billed to this transporter (Sprint 2B)
  fundedDriverAdvances DriverSettlement[] @relation("FundedDriverAdvances") // Sprint 2C
  // Removed vehicles relation as per sprint-1a

  @@unique([organizationId, firmName])
  @@index([organizationId])
}

// ═════════════════════════════════════════════════
// MASTER DATA — VEHICLES
// ═════════════════════════════════════════════════

enum OwnershipStatus {
  OWNED
  ATTACHED
  RENTED
  LEASED
  PARTNERSHIP
}

model Vehicle {
  id                   String          @id @default(cuid())
  organizationId       String
  organization         Organization    @relation(fields: [organizationId], references: [id])
  vehicleNumber        String
  make                 String?
  model                String?
  year                 Int?
  ownershipStatus      OwnershipStatus @default(OWNED)
  chassisNumber        String?
  engineNumber         String?
  insuranceExpiry      DateTime?
  pucExpiry            DateTime?
  fitnessExpiry        DateTime?
  permitExpiry         DateTime?
  nationalPermitExpiry DateTime?
  currentDriverId      String?         @unique
  currentDriver        Driver?         @relation("CurrentVehicle", fields: [currentDriverId], references: [id])
  isActive             Boolean         @default(true)
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  // REMOVED: transporterId and transporter relation
  // ADDED: vehicleSource for attached/rented/leased vehicles
  vehicleSourceId String?
  vehicleSource   LedgerAccount?   @relation("VehicleSource", fields: [vehicleSourceId], references: [id])
  loans           VehicleLoan[]
  trips           Trip[]
  expenses        VehicleExpense[]
  // Removed index on transporterId

  @@unique([organizationId, vehicleNumber])
  @@index([organizationId])
}

// ═════════════════════════════════════════════════
// MASTER DATA — DRIVERS
// ═════════════════════════════════════════════════

model Driver {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  name             String
  phone            String?
  licenseNumber    String?
  licenseExpiry    DateTime?
  aadhaarNumber    String? // encrypted at rest
  panNumber        String? // encrypted at rest
  bankAccount      String? // encrypted at rest
  bankIfsc         String?
  address          String?
  monthlySalary    Decimal      @default(0) @db.Decimal(12, 2)
  dailyExpenseRate Decimal      @default(0) @db.Decimal(12, 2)
  isActive         Boolean      @default(true)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user            User? // for DRIVER self-login
  vehicle         Vehicle?           @relation("CurrentVehicle")
  tripAssignments TripDriver[]
  expenses        TripExpense[]      @relation("DriverExpenses")
  settlements     DriverSettlement[]

  @@index([organizationId])
}

// ═════════════════════════════════════════════════
// MASTER DATA — PARTIES (CONSIGNOR/CONSIGNEE)
// ═════════════════════════════════════════════════

model Party {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  partyName      String
  gstNumber      String?
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tripsConsignor Trip[] @relation("Consignor")
  tripsConsignee Trip[] @relation("Consignee")

  @@index([organizationId])
}

// ════════════════════════════════════════════════
// MASTER DATA — ROUTES & RATE CARDS
// ═════════════════════════════════════════════════

model Route {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  origin         String
  destination    String
  distanceKm     Float?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  rateCards RateCard[]
  trips     Trip[]

  @@unique([organizationId, origin, destination])
  @@index([organizationId])
}

model RateCard {
  id            String      @id @default(cuid())
  transporterId String
  transporter   Transporter @relation(fields: [transporterId], references: [id])
  routeId       String
  route         Route       @relation(fields: [routeId], references: [id])
  ratePerTon    Decimal     @db.Decimal(12, 2)
  validFrom     DateTime    @default(now())
  validUntil    DateTime?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([transporterId, routeId])
}

// ═════════════════════════════════════════════════
// NEW: LEDGER ACCOUNT SYSTEM (KHATA)
// ═════════════════════════════════════════════════

enum LedgerAccountKind {
  FINANCIER // bank / financier a vehicle loan is owed to
  VEHICLE_SUPPLIER // external owner of an attached/rented/leased vehicle
  VENDOR // reserved for future (diesel pump, mechanic) — allowed but no UI/logic this sprint
  PARTNER // reserved for future (partnership vehicle co-owner)
}

enum LedgerEntryType {
  DEBIT // increases what the fleet owner OWES this account (a charge: EMI due, hire charge due)
  CREDIT // decreases what is owed (a payment the fleet owner made to this account)
}

enum LoanStatus {
  ACTIVE
  CLOSED
  DEFAULTED
}

model LedgerAccount {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  kind           LedgerAccountKind
  name           String
  contactPerson  String?
  phone          String?
  notes          String?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  entries          LedgerEntry[]
  vehicleLoans     VehicleLoan[] @relation("LoanFinancier")
  suppliedVehicles Vehicle[]     @relation("VehicleSource")

  @@unique([organizationId, kind, name])
  @@index([organizationId, kind])
}

// ═════════════════════════════════════════════════
// NEW: LEDGER ENTRY (APPEND-ONLY RUNNING-BALANCE ROWS)
// ═════════════════════════════════════════════════

model LedgerEntry {
  id             String          @id @default(cuid())
  organizationId String
  accountId      String
  account        LedgerAccount   @relation(fields: [accountId], references: [id])
  type           LedgerEntryType
  amount         Decimal         @db.Decimal(12, 2)
  description    String?
  date           DateTime        @default(now())
  source         String          @default("MANUAL") // MANUAL | EMI_ACCRUAL | future values
  relatedType    String? // e.g. "VEHICLE_LOAN", "VEHICLE" — soft link, no FK
  relatedId      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([accountId, date])
  @@index([organizationId])
}

// ═════════════════════════════════════════════════
// NEW: VEHICLE LOAN (EMI)
// ═════════════════════════════════════════════════

model VehicleLoan {
  id                 String        @id @default(cuid())
  organizationId     String
  vehicleId          String
  vehicle            Vehicle       @relation(fields: [vehicleId], references: [id])
  financierAccountId String
  financierAccount   LedgerAccount @relation("LoanFinancier", fields: [financierAccountId], references: [id])
  principal          Decimal       @db.Decimal(12, 2)
  emiAmount          Decimal       @db.Decimal(12, 2)
  emiDueDay          Int // 1-31
  tenureMonths       Int
  startDate          DateTime
  status             LoanStatus    @default(ACTIVE)
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([organizationId, vehicleId])
}

// ═════════════════════════════════════════════════
// CORE — TRIPS
// ═════════════════════════════════════════════════

enum TripStatus {
  DRAFT
  LOADING
  IN_TRANSIT
  DELIVERED
  POD_RECEIVED
  BILLED
  SETTLED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERPAID
}

model Trip {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  transporterId  String
  transporter    Transporter  @relation(fields: [transporterId], references: [id])
  vehicleId      String
  vehicle        Vehicle      @relation(fields: [vehicleId], references: [id])
  routeId        String?
  route          Route?       @relation(fields: [routeId], references: [id])
  consignorId    String?
  consignor      Party?       @relation("Consignor", fields: [consignorId], references: [id])
  consigneeId    String?
  consignee      Party?       @relation("Consignee", fields: [consigneeId], references: [id])

  // Trip details
  tripDate        DateTime       @default(now())
  material        String?
  weightTons      Decimal        @default(0) @db.Decimal(10, 3)
  freightAmount   Decimal        @default(0) @db.Decimal(12, 2)
  freightPerTon   Decimal?
  advanceGiven    Decimal        @default(0) @db.Decimal(12, 2)
  commissionType  CommissionType
  commissionValue Decimal        @db.Decimal(12, 2)
  notes           String?
  internalRef     String? // your handwritten bilty number
  lrNumber        String? // LR (Lorry Receipt) number

  // Status
  status        TripStatus    @default(DRAFT)
  paymentStatus PaymentStatus @default(UNPAID)

  // Dates
  loadingDate     DateTime?
  departureDate   DateTime?
  deliveryDate    DateTime?
  podReceivedDate DateTime?
  billedDate      DateTime?
  settledDate     DateTime?

  // POD
  podImageUrl String?
  podNotes    String?

  // Audit
  createdById String
  createdBy   User     @relation("TripCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  drivers       TripDriver[]
  expenses      TripExpense[]
  ledgerEntries TransporterLedgerEntry[]
  payments      Payment[]
  // Multi-stop capability (Sprint 2B). Empty for legacy single-leg trips,
  // which continue to use the transporterId/freightAmount/commission fields
  // directly on the Trip above, exactly as before.
  stops         TripStop[]
  loads         TripLoad[]
  // Multiple PODs — one journey can be delivered at several stops, each with
  // its own proof. The legacy single podImageUrl/podReceivedDate fields above
  // are untouched; this is additive.
  pods          TripPod[]

  @@unique([organizationId, internalRef])
  @@index([organizationId])
  @@index([transporterId])
  @@index([vehicleId])
  @@index([status])
  @@index([createdAt])
}

// ═════════════════════════════════════════════════
// TRIP → DRIVER (MANY-TO-MANY)
// ═════════════════════════════════════════════════

model TripDriver {
  id       String    @id @default(cuid())
  tripId   String
  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driverId String
  driver   Driver    @relation(fields: [driverId], references: [id])
  role     String    @default("PRIMARY") // PRIMARY | RELIEF | CO_DRIVER
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  @@unique([tripId, driverId])
}

// ═════════════════════════════════════════════════
// TRIP EXPENSES
// ═════════════════════════════════════════════════

enum ExpenseCategory {
  FUEL
  TOLL
  FOOD
  LOADING_UNLOADING
  REPAIR_EN_ROUTE
  EMERGENCY
  DAILY_EXPENSE
  OTHER
}

model TripExpense {
  id             String          @id @default(cuid())
  tripId         String
  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category       ExpenseCategory
  amount         Decimal         @db.Decimal(12, 2)
  description    String?
  date           DateTime        @default(now())
  paidToDriverId String?
  paidToDriver   Driver?         @relation("DriverExpenses", fields: [paidToDriverId], references: [id])
  receiptUrl     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([tripId])
}

// ═════════════════════════════════════════════════
// TRANSPORTER LEDGER (per-trip entries)
// ═════════════════════════════════════════════════

model TransporterLedgerEntry {
  id                 String      @id @default(cuid())
  transporterId      String
  transporter        Transporter @relation(fields: [transporterId], references: [id])
  tripId             String
  trip               Trip        @relation(fields: [tripId], references: [id])
  freightCredited    Decimal     @default(0) @db.Decimal(12, 2)
  commissionDeducted Decimal     @default(0) @db.Decimal(12, 2)
  netReceivable      Decimal     @default(0) @db.Decimal(12, 2) // freight - commission
  outstandingBefore  Decimal     @default(0) @db.Decimal(12, 2)
  outstandingAfter   Decimal     @default(0) @db.Decimal(12, 2)
  createdAt          DateTime    @default(now())

  @@index([transporterId])
  @@index([tripId])
}

// ═════════════════════════════════════════════════
// PAYMENTS
// ═════════════════════════════════════════════════

enum PaymentMode {
  CASH
  BANK_TRANSFER
  UPI
  CHEQUE
}

enum PaymentType {
  ADVANCE
  DIESEL_ADVANCE
  PART_PAYMENT
  FULL_SETTLEMENT
  OTHER
}

model Payment {
  id              String      @id @default(cuid())
  transporterId   String
  transporter     Transporter @relation(fields: [transporterId], references: [id])
  tripId          String?
  trip            Trip?       @relation(fields: [tripId], references: [id])
  // Multi-stop billing (Sprint 2B). When a payment settles a specific leg of
  // a multi-stop trip, loadId points at that TripLoad. Null for every legacy
  // single-leg payment, where tripId alone means what it always has.
  loadId          String?
  load            TripLoad?   @relation(fields: [loadId], references: [id])
  amount          Decimal     @db.Decimal(12, 2)
  // 1% TDS withheld on non-cash payments. Recorded for the client's tax
  // filing only — it is NOT subtracted from `amount` and does NOT affect
  // outstanding/receivable math, which continues to use the gross `amount`.
  tdsAmount       Decimal     @default(0) @db.Decimal(12, 2)
  paymentType     PaymentType @default(OTHER)
  mode            PaymentMode
  referenceNumber String? // cheque number, UTR, UPI ref
  bankAccount     String? // which of your accounts it landed in
  notes           String?
  paymentDate     DateTime    @default(now())
  createdById     String
  createdBy       User        @relation("PaymentCreator", fields: [createdById], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([transporterId])
  @@index([tripId])
  @@index([loadId])
  @@index([paymentDate])
}

// ═════════════════════════════════════════════════
// MULTI-STOP TRIPS (Sprint 2B) — additive, opt-in
// ═════════════════════════════════════════════════
// A single physical journey (one truck, one round) can pick up and drop at
// several places, and different pickup→drop legs can belong to different
// transporters. Legacy single-leg trips have no stops/loads and keep billing
// off the fields directly on Trip. A trip is "multi-stop" purely by having
// TripLoad rows — there is no flag column.

model TripStop {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sequence    Int // 0-based order along the journey
  location    String // free text, same convention as Route.origin/destination
  arrivalDate DateTime?
  createdAt   DateTime  @default(now())

  loadsOriginating TripLoad[] @relation("LoadOrigin")
  loadsDestined    TripLoad[] @relation("LoadDestination")
  pods             TripPod[]

  @@index([tripId, sequence])
}

model TripLoad {
  id                String         @id @default(cuid())
  tripId            String
  trip              Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  originStopId      String
  originStop        TripStop       @relation("LoadOrigin", fields: [originStopId], references: [id])
  destinationStopId String
  destinationStop   TripStop       @relation("LoadDestination", fields: [destinationStopId], references: [id])
  transporterId     String
  transporter       Transporter    @relation(fields: [transporterId], references: [id])
  weightTons        Decimal        @default(0) @db.Decimal(10, 3)
  freightAmount     Decimal        @default(0) @db.Decimal(12, 2)
  freightPerTon     Decimal?
  commissionType    CommissionType
  commissionValue   Decimal        @db.Decimal(12, 2)
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  payments Payment[]

  @@index([tripId])
  @@index([transporterId])
}

// One proof-of-delivery per delivered stop. Additive to the legacy single POD
// on Trip — a multi-stop journey drops at several places and needs one each.
model TripPod {
  id           String    @id @default(cuid())
  tripId       String
  trip         Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stopId       String?
  stop         TripStop? @relation(fields: [stopId], references: [id])
  location     String? // free-text place if not tied to a specific stop
  note         String?
  imageUrl     String?
  receivedDate DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([tripId])
}

// ═════════════════════════════════════════════════
// DRIVER SETTLEMENTS
// ═════════════════════════════════════════════════

enum SettlementType {
  SALARY
  INCENTIVE
  ADVANCE
  DEDUCTION
  PENALTY
  CASH_COLLECTED
  ALLOWANCE
  EXPENSE_REIMBURSEMENT
}

model DriverSettlement {
  id          String         @id @default(cuid())
  driverId    String
  driver      Driver         @relation(fields: [driverId], references: [id])
  tripId      String?
  type        SettlementType
  amount      Decimal        @db.Decimal(12, 2)
  description String?
  date        DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Sprint 2C: when set, this ADVANCE was cash a specific transporter handed
  // the driver directly (not company money) — it reduces both the driver's
  // owed balance AND that transporter's outstanding. Null (default) means a
  // normal company-funded advance/settlement — zero change to that path.
  fundedByTransporterId String?
  fundedByTransporter   Transporter? @relation("FundedDriverAdvances", fields: [fundedByTransporterId], references: [id])

  @@index([driverId])
  @@index([date])
  @@index([fundedByTransporterId])
}

// ═════════════════════════════════════════════════
// VEHICLE EXPENSES (non-trip)
// ═════════════════════════════════════════════════

enum VehicleExpenseCategory {
  REPAIR
  MAINTENANCE
  TYRE
  BATTERY
  INSURANCE
  PERMIT
  OTHER
}

model VehicleExpense {
  id          String                 @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle                @relation(fields: [vehicleId], references: [id])
  category    VehicleExpenseCategory
  amount      Decimal                @db.Decimal(12, 2)
  description String?
  date        DateTime               @default(now())
  receiptUrl  String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([vehicleId])
}

// ═════════════════════════════════════════════════
// DOCUMENTS
// ═════════════════════════════════════════════════

enum DocumentType {
  RC
  INSURANCE
  PUC
  FITNESS
  PERMIT
  NATIONAL_PERMIT
  POD
  LR
  DRIVER_LICENSE
  AADHAAR
  PAN
  OTHER
}

enum DocumentEntityType {
  VEHICLE
  DRIVER
  TRIP
  ORGANIZATION
}

model Document {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  type           DocumentType
  entityType     DocumentEntityType
  entityId       String // polymorphic FK
  title          String
  fileUrl        String?
  expiryDate     DateTime?
  reminderSent   Boolean            @default(false)
  notes          String?
  createdById    String
  createdBy      User               @relation("DocumentCreator", fields: [createdById], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([expiryDate])
}
