// Transport ERP — Prisma Schema
// Stack: PostgreSQL
// POC scope: Trip -> Ledger auto-posting

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ORGANISATION (ready for multi-tenant Phase 2, unused in POC UI) ───────────
model Organisation {
  id         String   @id @default(uuid())
  name       String
  createdAt  DateTime @default(now())

  vehicles     Vehicle[]
  drivers      Driver[]
  transporters Transporter[]
  parties      Party[]
  routes       Route[]
  trips        Trip[]
}

// ─── VEHICLE ─────────────────────────────────────────────────────────────────
model Vehicle {
  id               String   @id @default(uuid())
  orgId            String
  vehicleNumber    String   @unique
  capacity         Float    // in tonnes
  ownershipStatus  String   @default("own") // own | attached
  createdAt        DateTime @default(now())

  org   Organisation @relation(fields: [orgId], references: [id])
  trips Trip[]
}

// ─── DRIVER ──────────────────────────────────────────────────────────────────
model Driver {
  id            String   @id @default(uuid())
  orgId         String
  name          String
  licenseNumber String?
  mobileNumber  String?
  createdAt     DateTime @default(now())

  org   Organisation @relation(fields: [orgId], references: [id])
  trips Trip[]
}

// ─── TRANSPORTER ─────────────────────────────────────────────────────────────
model Transporter {
  id               String   @id @default(uuid())
  orgId            String
  firmName         String
  contactName      String?
  mobileNumber     String?
  commissionType   String   @default("percentage") // percentage | fixed
  commissionValue  Float    @default(0)
  bankName         String?
  bankAccount      String?
  ifsc             String?
  createdAt        DateTime @default(now())

  org        Organisation       @relation(fields: [orgId], references: [id])
  ratecards  RateCard[]
  trips      Trip[]
  ledger     TransporterLedger[]
  payments   TransporterPayment[]
}

// ─── PARTY (consignor / consignee) ───────────────────────────────────────────
model Party {
  id          String   @id @default(uuid())
  orgId       String
  partyName   String
  gstNumber   String?
  mobileNumber String?
  createdAt   DateTime @default(now())

  org   Organisation @relation(fields: [orgId], references: [id])
  trips Trip[]
}

// ─── ROUTE ───────────────────────────────────────────────────────────────────
model Route {
  id          String   @id @default(uuid())
  orgId       String
  origin      String
  destination String
  createdAt   DateTime @default(now())

  org       Organisation @relation(fields: [orgId], references: [id])
  ratecards RateCard[]
  trips     Trip[]
}

// ─── RATE CARD (Transporter x Route -> rate) ─────────────────────────────────
model RateCard {
  id             String   @id @default(uuid())
  transporterId  String
  routeId        String
  ratePerUnit    Float    // rate per tonne (or per trip — set by transporter)
  unit           String   @default("tonne") // tonne | trip
  createdAt      DateTime @default(now())

  transporter Transporter @relation(fields: [transporterId], references: [id])
  route       Route       @relation(fields: [routeId], references: [id])

  @@unique([transporterId, routeId])
}

// ─── TRIP ─────────────────────────────────────────────────────────────────────
model Trip {
  id            String   @id @default(uuid())
  orgId         String
  transporterId String
  vehicleId     String
  driverId      String
  routeId       String
  partyId       String?

  quantity      Float    // tonnes or units carried
  freightTotal  Float    // auto-calculated: ratePerUnit * quantity
  paymentMode   String   @default("bank") // bank | road (cash on road)

  status        String   @default("open") // open | delivered | closed
  tripDate      DateTime @default(now())
  podFileUrl    String?  // uploaded POD image path
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org         Organisation @relation(fields: [orgId], references: [id])
  transporter Transporter  @relation(fields: [transporterId], references: [id])
  vehicle     Vehicle      @relation(fields: [vehicleId], references: [id])
  driver      Driver       @relation(fields: [driverId], references: [id])
  route       Route        @relation(fields: [routeId], references: [id])
  party       Party?       @relation(fields: [partyId], references: [id])
  ledgerEntry TransporterLedger?
}

// ─── TRANSPORTER LEDGER ───────────────────────────────────────────────────────
// One entry per closed trip. Tracks freight, commission, net payable.
model TransporterLedger {
  id                   String   @id @default(uuid())
  transporterId        String
  tripId               String   @unique

  freightCredited      Float    // = trip.freightTotal
  commissionDeducted   Float    // calculated from transporter commission settings
  tdsDeducted          Float    @default(0)
  netPayable           Float    // freightCredited - commissionDeducted - tdsDeducted

  paymentReceived      Float    @default(0)
  outstandingBalance   Float    // netPayable - paymentReceived (running)
  entryDate            DateTime @default(now())

  transporter Transporter @relation(fields: [transporterId], references: [id])
  trip        Trip        @relation(fields: [tripId], references: [id])
}

// ─── TRANSPORTER PAYMENTS ─────────────────────────────────────────────────────
// Standalone payment record (not tied to a single trip)
model TransporterPayment {
  id            String   @id @default(uuid())
  transporterId String
  amount        Float
  mode          String   @default("bank") // bank | cash
  bankReference String?
  paymentDate   DateTime @default(now())
  notes         String?

  transporter Transporter @relation(fields: [transporterId], references: [id])
}
